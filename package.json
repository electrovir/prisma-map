{
    "name": "prisma-map",
    "version": "1.0.4",
    "description": "Map generated Prisma types and runtime field values however you like.",
    "keywords": [
        "prisma",
        "plugin",
        "extension",
        "generator",
        "vir"
    ],
    "homepage": "https://github.com/electrovir/prisma-map",
    "bugs": {
        "url": "https://github.com/electrovir/prisma-map/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/electrovir/prisma-map.git"
    },
    "license": "(MIT or CC0 1.0)",
    "author": {
        "name": "electrovir",
        "url": "https://github.com/electrovir"
    },
    "type": "module",
    "main": "src/index.ts",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "bin": "bin.js",
    "scripts": {
        "compile": "npm run setup && virmator compile",
        "docs": "virmator docs",
        "format": "virmator format",
        "lint": "virmator lint fix",
        "publish": "virmator publish npm run test:all",
        "setup": "tsx src/setup/setup-dev.script.mock.ts",
        "test": "virmator test node",
        "test:all": "npm run compile && concurrently --colors --kill-others-on-fail -c auto --names tests,spelling,format,docs,deps,lint \"npm run test:coverage\" \"npm run test:spelling\" \"npm run test:format\" \"npm run test:docs\" \"npm run test:deps\" \"npm run test:lint\"",
        "test:coverage": "npm run test coverage",
        "test:deps": "virmator deps check",
        "test:docs": "virmator docs check",
        "test:format": "virmator format check",
        "test:lint": "virmator lint",
        "test:spelling": "virmator spellcheck",
        "test:update": "npm run test update"
    },
    "dependencies": {
        "@augment-vir/assert": "^31.9.4",
        "@augment-vir/common": "^31.9.4",
        "@augment-vir/node": "^31.9.4",
        "fsm-vir": "^2.0.0",
        "object-shape-tester": "^5.1.4",
        "type-fest": "^4.37.0"
    },
    "devDependencies": {
        "@augment-vir/test": "^31.9.4",
        "@eslint/eslintrc": "^3.3.0",
        "@eslint/js": "^9.20.0",
        "@prisma/client": "^6.4.1",
        "@prisma/generator-helper": "^6.4.1",
        "@prisma/internals": "^6.4.1",
        "@stylistic/eslint-plugin": "^4.2.0",
        "@stylistic/eslint-plugin-ts": "^4.2.0",
        "@types/node": "^22.13.9",
        "@typescript-eslint/eslint-plugin": "^8.26.0",
        "c8": "^10.1.3",
        "cspell": "^8.17.5",
        "date-vir": "^7.2.1",
        "dependency-cruiser": "^16.10.0",
        "disparity": "^3.2.0",
        "esbuild": "^0.25.0",
        "eslint": "^9.20.1",
        "eslint-config-prettier": "^10.0.2",
        "eslint-plugin-jsdoc": "^50.6.3",
        "eslint-plugin-monorepo-cop": "^1.0.2",
        "eslint-plugin-playwright": "^2.2.0",
        "eslint-plugin-prettier": "^5.2.3",
        "eslint-plugin-require-extensions": "^0.1.3",
        "eslint-plugin-sonarjs": "^3.0.2",
        "eslint-plugin-unicorn": "^57.0.0",
        "istanbul-smart-text-reporter": "^1.1.5",
        "markdown-code-example-inserter": "^3.0.3",
        "npm-check-updates": "^17.1.15",
        "prettier": "^3.3.3",
        "prettier-plugin-interpolated-html-tags": "^2.0.1",
        "prettier-plugin-jsdoc": "^1.3.2",
        "prettier-plugin-multiline-arrays": "^4.0.2",
        "prettier-plugin-organize-imports": "^4.1.0",
        "prettier-plugin-packagejson": "^2.5.10",
        "prettier-plugin-sort-json": "^4.1.1",
        "prettier-plugin-toml": "^2.0.2",
        "prisma": "^6.4.1",
        "typedoc": "^0.27.9",
        "typescript": "^5.8.2",
        "typescript-eslint": "^8.26.0",
        "virmator": "^13.13.1"
    },
    "peerDependencies": {
        "@prisma/client": "*",
        "@prisma/generator-helper": "*",
        "@prisma/internals": "*"
    },
    "engines": {
        "node": ">=22"
    }
}
