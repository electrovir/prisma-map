{
    "name": "prisma-map",
    "version": "3.0.1",
    "description": "Map generated Prisma types and runtime field values however you like.",
    "keywords": [
        "prisma",
        "plugin",
        "extension",
        "vir"
    ],
    "homepage": "https://github.com/electrovir/prisma-map",
    "bugs": {
        "url": "https://github.com/electrovir/prisma-map/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/electrovir/prisma-map.git"
    },
    "license": "(MIT or CC0 1.0)",
    "author": {
        "name": "electrovir",
        "url": "https://github.com/electrovir"
    },
    "type": "module",
    "main": "src/index.ts",
    "module": "src/index.ts",
    "types": "src/index.ts",
    "scripts": {
        "compile": "npm run setup && virmator compile",
        "docs": "virmator docs",
        "format": "virmator format",
        "lint": "virmator lint fix",
        "publish": "virmator publish npm run test:all",
        "setup": "tsx src/setup/setup-dev.script.mock.ts",
        "test": "virmator test node",
        "test:all": "npm run compile && runstorm --names tests,spelling,format,docs,deps,lint \"npm run test:coverage\" \"npm run test:spelling\" \"npm run test:format\" \"npm run test:docs\" \"npm run test:deps\" \"npm run test:lint\"",
        "test:coverage": "npm run test coverage",
        "test:deps": "virmator deps check",
        "test:docs": "virmator docs check",
        "test:format": "virmator format check",
        "test:lint": "virmator lint",
        "test:spelling": "virmator spellcheck",
        "test:update": "npm run test update"
    },
    "dependencies": {
        "@augment-vir/assert": "^31.39.0",
        "@augment-vir/common": "^31.39.0",
        "@augment-vir/node": "^31.39.0",
        "fsm-vir": "^3.0.0",
        "object-shape-tester": "^6.6.0",
        "tsx": "^4.20.6",
        "type-fest": "^5.0.1"
    },
    "devDependencies": {
        "@augment-vir/test": "^31.39.0",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.37.0",
        "@prisma/client": "6.16.3",
        "@prisma/generator-helper": "6.16.3",
        "@prisma/internals": "6.16.3",
        "@stylistic/eslint-plugin": "^5.4.0",
        "@stylistic/eslint-plugin-ts": "^4.4.1",
        "@types/node": "^24.7.0",
        "@typescript-eslint/eslint-plugin": "^8.46.0",
        "c8": "^10.1.3",
        "cspell": "^9.2.1",
        "date-vir": "^7.4.2",
        "dependency-cruiser": "^17.0.2",
        "disparity": "^3.2.0",
        "esbuild": "^0.25.10",
        "eslint": "^9.37.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^60.8.3",
        "eslint-plugin-monorepo-cop": "^1.0.2",
        "eslint-plugin-playwright": "^2.2.2",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-require-extensions": "^0.1.3",
        "eslint-plugin-sonarjs": "^3.0.5",
        "eslint-plugin-unicorn": "^57.0.0",
        "istanbul-smart-text-reporter": "^1.1.5",
        "markdown-code-example-inserter": "^3.0.3",
        "npm-check-updates": "^19.0.0",
        "prettier": "~3.3.3",
        "prettier-plugin-interpolated-html-tags": "^2.0.1",
        "prettier-plugin-jsdoc": "^1.3.3",
        "prettier-plugin-multiline-arrays": "^4.0.3",
        "prettier-plugin-organize-imports": "^4.3.0",
        "prettier-plugin-packagejson": "^2.5.19",
        "prettier-plugin-sort-json": "^4.1.1",
        "prettier-plugin-toml": "^2.0.6",
        "prisma": "6.16.3",
        "prisma-vir": "^1.0.1",
        "runstorm": "^0.6.2",
        "typedoc": "^0.28.13",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.46.0",
        "virmator": "^14.1.0"
    },
    "peerDependencies": {
        "@prisma/generator-helper": "*",
        "@prisma/internals": "*"
    },
    "engines": {
        "node": ">=22"
    }
}
