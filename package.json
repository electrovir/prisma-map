        "eslint-plugin-sonarjs": "^3.0.1",
        "eslint-plugin-unicorn": "^56.0.1",
        "markdown-code-example-inserter": "^3.0.3",
        "npm-check-updates": "^17.1.13",
        "prettier": "^3.3.3",
        "prettier-plugin-interpolated-html-tags": "^2.0.0",
        "prettier-plugin-jsdoc": "^1.3.2",
