generator jsClient {
    provider = "prisma-client-js"
    output   = "prisma-output"
}

generator mappedClient {
    provider = "prisma-map"
    config   = "./config.ts"
}

datasource db {
    provider = "sqlite"
    url      = "file:./db.db"
}

model User {
    id        String   @id @default(cuid(2))
    createdAt DateTime @default(now())

    email String
}
